<head>
  <meta charset="utf-8">
  <meta name="generator" content="{{ eleventy.generator }}">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or metadata.title }}</title>
  <meta name="description" content="{{ excerpt or metaDescription or eleventyComputed.metaDescription or metadata.description }}">
  <meta property="og:title" content="{{ title or metadata.title }}">
  <meta property="og:description" content="{{ excerpt or metaDescription or eleventyComputed.metaDescription or metadata.description }}">
  <meta property="og:url" content="https://sidehustlersband.com{{ page.url }}">
  <meta property="og:image" content="https://sidehustlersband.com{{ image or '/static/img/sidehustlers-cartoon-nov-21-2025.png' }}">
  <meta property="og:image:height" content="630" />

  {% set css %}
    {% include "assets/css/inline.css" %}
    {% include "assets/css/micromodal.css" %}
  {% endset %}
  <style>{{ css | cssmin | safe }}</style>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Goblin+One&family=Smokum&display=swap" rel="stylesheet">
{% set js %}
    {% include "assets/js/micromodal.min.js" %}
    {% include "assets/js/inline.js" %}
  {% endset %}
  <script>{{ js | jsmin | safe }}</script>
</head>
